{
  "$schema": "./extgen.schema.json",
  "input": "./spec.gmidl",
  "root": "./",
  "profile": "Full",
  "gamemaker": {
    "wrappers": {
      "enabled": true,
      "outputFile": "../scripts/IConsole/IConsole.gml"
    },
    "runtime": {
      "enabled": false
    },
    "injectors": {
      "enabled": false
    }
  },
  "targets": {
    "sourceFolder": "./native",
    "sourceFile": "{0}_native",
    "windows": {
      "enabled": true,
      "outputFolder": "./"
    },
    "macos": {
      "enabled": false
    },
    "linux": {
      "enabled": false
    }
  },
  "extras": {},
  "build": {
    "emitCmake": true,
    "cmake": {
      "cppStandard": 20,
      "cppExtensions": false,
      "strictWarnings": true,
      "useThirdParty": false,
      "emitPresets": true
    }
  }
}